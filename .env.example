APP_URL=https://cms.shyfted.com.au
DATABASE_URL=sqlite:///data/cms.db
AUTH_SESSION_SECRET=replace-with-a-long-random-secret

# Sessions
SESSION_LIFETIME_HOURS=8
SESSION_COOKIE_SECURE=true

# Password resets and request throttling
RESET_TOKEN_MINUTES=30
LOGIN_RATE_LIMIT=5
RESET_RATE_LIMIT=5
RATE_LIMIT_WINDOW_MINUTES=15

# Email delivery for password reset links
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM="Shyfted CMS <cms@shyfted.com.au>"
SMTP_USE_TLS=true
